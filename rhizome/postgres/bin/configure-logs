#!/bin/env ruby
# frozen_string_literal: true

require "json"
require_relative "../../common/lib/util"
require_relative "../lib/vector_log_config"

config = JSON.parse($stdin.read)
resource_id = config["resource_id"]
instance = config["instance"]
server_role = config["server_role"]
log_dir = config["log_dir"]
vector_version = config["vector_version"]
parseable_endpoint = config["parseable_endpoint"]
parseable_username = config["parseable_username"]
parseable_password = config["parseable_password"]
parseable_ca_bundle = config["parseable_ca_bundle"]
parseable_server_name = config["parseable_server_name"]

vector_current = begin
  r("vector --version")
rescue
  ""
end
unless vector_current.start_with?("vector #{vector_version}")
  r "wget -q https://github.com/vectordotdev/vector/releases/download/v#{vector_version}/vector-#{vector_version}-x86_64-unknown-linux-gnu.tar.gz -O /tmp/vector.tar.gz"
  r "tar -xzf /tmp/vector.tar.gz --strip-components=3 -C /usr/local/bin ./vector-x86_64-unknown-linux-gnu/bin/vector"
  r "chmod +x /usr/local/bin/vector"
  r "rm /tmp/vector.tar.gz"
end

r "usermod -aG systemd-journal ubi_monitoring"
r "usermod -aG postgres ubi_monitoring"

log_config = VectorLogConfig.new(
  resource_id: resource_id,
  instance: instance,
  server_role: server_role,
  log_dir: log_dir,
  parseable_endpoint: parseable_endpoint,
  parseable_username: parseable_username,
  parseable_password: parseable_password,
  parseable_ca_bundle: parseable_ca_bundle,
  parseable_server_name: parseable_server_name
)

if log_config.use_tls?
  r "mkdir -p /etc/vector/certs"
  safe_write_to_file(log_config.ca_cert_path, parseable_ca_bundle)
end

tls_curl_flag = log_config.use_tls? ? "--cacert #{log_config.ca_cert_path}" : "-k"
r "curl -sf #{tls_curl_flag} -u '#{parseable_username}:#{parseable_password}' -X PUT '#{parseable_endpoint}/api/v1/logstream/#{resource_id}' || true"

r "mkdir -p /etc/vector /var/lib/vector"
safe_write_to_file("/etc/vector/postgres.toml", log_config.to_toml)

vector_service = <<~SERVICE
  [Unit]
  Description=Vector log shipper for PostgreSQL
  After=network.target

  [Service]
  Type=simple
  User=root
  ExecStart=/usr/local/bin/vector --config /etc/vector/postgres.toml
  Restart=on-failure
  RestartSec=5

  [Install]
  WantedBy=multi-user.target
SERVICE

safe_write_to_file("/etc/systemd/system/vector-postgres.service", vector_service)
r "systemctl daemon-reload"
r "systemctl enable vector-postgres --now"
r "systemctl restart vector-postgres"
