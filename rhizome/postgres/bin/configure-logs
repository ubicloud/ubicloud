#!/bin/env ruby
# frozen_string_literal: true

require "json"
require_relative "../../common/lib/util"

config = JSON.parse($stdin.read)
version = config["version"]
resource_id = config["resource_id"]
log_dir = config["log_dir"]
parseable_endpoint = config["parseable_endpoint"]
parseable_username = config["parseable_username"]
parseable_password = config["parseable_password"]
parseable_ca_bundle = config["parseable_ca_bundle"]

begin
  r "dpkg -s syslog-ng syslog-ng-mod-http"
rescue CommandFail
  r "apt-get update -qq"
  r "apt-get install -y -q syslog-ng syslog-ng-mod-http"
end

r "usermod -aG postgres ubi_monitoring"

if parseable_ca_bundle
  r "mkdir -p /etc/syslog-ng/certs"
  safe_write_to_file("/etc/syslog-ng/certs/parseable-ca.crt", parseable_ca_bundle)
end

use_tls = parseable_ca_bundle && parseable_endpoint.start_with?("https://")
tls_block = use_tls ? %( tls(ca-file("/etc/syslog-ng/certs/parseable-ca.crt") peer-verify(yes))) : ""

tls_curl_flag = use_tls ? "--cacert /etc/syslog-ng/certs/parseable-ca.crt" : "-k"
r "curl -sf #{tls_curl_flag} -u '#{parseable_username}:#{parseable_password}' -X PUT '#{parseable_endpoint}/api/v1/logstream/#{resource_id}' || true"

http_destination = lambda { |label, body|
  <<~DEST
    destination d_parseable_#{label} {
      http(
        url("#{parseable_endpoint}/api/v1/logstream/#{resource_id}")
        method("POST")
        user("#{parseable_username}")
        password("#{parseable_password}")
        headers("Content-Type: application/json")
        body(#{body})
        persist-name("parseable_#{label}")
        workers(1)
        batch-lines(1)
        batch-timeout(10000)
        timeout(30)
        retries(3)
        #{tls_block}
      );
    };
  DEST
}

syslog_ng_conf = <<~CONF
  options {
    keep-hostname(yes);
    use-fqdn(no);
  };

  source s_pglog {
    wildcard-file(
      base-dir("#{log_dir}")
      filename-pattern("postgresql-*.json")
      flags(no-parse)
      follow-freq(5)
    );
  };

  filter f_postgres_units {
    match("postgresql@" value(".journald._SYSTEMD_UNIT")) or
    match("pgbouncer@" value(".journald._SYSTEMD_UNIT")) or
    match("upgrade_postgres" value(".journald._SYSTEMD_UNIT"));
  };

  #{http_destination.call("pglog", '"[${MESSAGE}]"')}
  #{http_destination.call("journal", %('[{"stream":"journal","ts":"${ISODATE}","unit":"${PROGRAM}","priority":${LEVEL_NUM},"msg":"${MSG}"}]'))}

  log { source(s_pglog); destination(d_parseable_pglog); };
  log { source(s_src); filter(f_postgres_units); destination(d_parseable_journal); };
CONF

safe_write_to_file("/etc/syslog-ng/conf.d/postgres.conf", syslog_ng_conf)

r "sed -i 's/^#SYSLOGNG_OPTS=.*/SYSLOGNG_OPTS=\"--no-caps\"/' /etc/default/syslog-ng"

r "systemctl enable syslog-ng --now"
r("systemctl restart syslog-ng", expect: [0, 1])
