#!/bin/env ruby
# frozen_string_literal: true

require "json"
require_relative "../../common/lib/util"
require_relative "../lib/otel_log_config"

config = JSON.parse($stdin.read)
resource_id = config["resource_id"]
instance = config["instance"]
server_role = config["server_role"]
log_dir = config["log_dir"]
otelcol_version = config["otelcol_version"]
parseable_endpoint = config["parseable_endpoint"]
parseable_username = config["parseable_username"]
parseable_password = config["parseable_password"]
parseable_ca_bundle = config["parseable_ca_bundle"]
parseable_server_name = config["parseable_server_name"]
log_destinations = (config["log_destinations"] || []).map { |d|
  {host: d["host"], port: d["port"], template: d["template"], ca_bundle: d["ca_bundle"]}
}

unless parseable_endpoint
  r "sudo systemctl stop otelcol-contrib || true"
  r "sudo systemctl disable otelcol-contrib || true"
  exit 0
end

otelcol_current = begin
  r("otelcol-contrib --version")
rescue
  ""
end
unless otelcol_current.include?(otelcol_version)
  arch = r("uname -m").strip == "aarch64" ? "arm64" : "amd64"
  r "wget -q https://github.com/open-telemetry/opentelemetry-collector-releases/releases/download/v#{otelcol_version}/otelcol-contrib_#{otelcol_version}_linux_#{arch}.tar.gz -O /tmp/otelcol.tar.gz"
  r "tar -xzf /tmp/otelcol.tar.gz -C /usr/local/bin otelcol-contrib"
  r "chmod +x /usr/local/bin/otelcol-contrib"
  r "rm /tmp/otelcol.tar.gz"
end

r "usermod -aG systemd-journal ubi_monitoring"
r "usermod -aG postgres ubi_monitoring"

tls_curl_flag = parseable_ca_bundle ? "--cacert #{OtelLogConfig::PARSEABLE_CA_CERT_PATH}" : "-k"
r "mkdir -p /etc/otelcol/certs /var/lib/otelcol/state /tmp/otelcol"
if parseable_ca_bundle
  safe_write_to_file(OtelLogConfig::PARSEABLE_CA_CERT_PATH, parseable_ca_bundle)
end
r "curl -sf #{tls_curl_flag} -u '#{parseable_username}:#{parseable_password}' -X PUT '#{parseable_endpoint}/api/v1/logstream/#{resource_id}' || true"

log_config = OtelLogConfig.new(
  resource_id: resource_id,
  instance: instance,
  server_role: server_role,
  log_dir: log_dir,
  parseable_endpoint: parseable_endpoint,
  parseable_username: parseable_username,
  parseable_password: parseable_password,
  parseable_ca_bundle: parseable_ca_bundle,
  parseable_server_name: parseable_server_name,
  log_destinations: log_destinations
)

log_destinations.each_with_index do |dest, i|
  next unless dest[:ca_bundle]
  safe_write_to_file(log_config.syslog_ca_cert_path(i), dest[:ca_bundle])
end

safe_write_to_file("/etc/otelcol/postgres.yaml", log_config.to_config)

otelcol_service = <<~SERVICE
  [Unit]
  Description=OpenTelemetry Collector for PostgreSQL logs
  After=network.target

  [Service]
  Type=simple
  User=root
  ExecStart=/usr/local/bin/otelcol-contrib --config /etc/otelcol/postgres.yaml
  Restart=on-failure
  RestartSec=5

  [Install]
  WantedBy=multi-user.target
SERVICE

safe_write_to_file("/etc/systemd/system/otelcol-contrib.service", otelcol_service)
r "systemctl daemon-reload"
r "systemctl enable otelcol-contrib --now"
r "systemctl reload otelcol-contrib || systemctl restart otelcol-contrib"
