#!/usr/bin/env bash

# Assemble instance-store NVMe write-through bcache in front of the persistent
# EBS data volume, then mount /dat. Idempotent: safe on first provision and on
# every boot. Instance store is wiped on stop/start while the EBS backing
# superblock survives, so only the disposable cache is (re)created here.

set -euo pipefail

# shellcheck disable=SC1091
. /etc/ubicloud-bcache.env

modprobe bcache

# Resolve devices by stable by-id symlinks; kernel nvme ordering reshuffles.
ebs_id="${VOLUME_ID/vol-/vol}"
ebs_dev=
for _ in $(seq 1 60); do
  ebs_dev=$(readlink -f "/dev/disk/by-id/nvme-Amazon_Elastic_Block_Store_${ebs_id}" 2>/dev/null || true)
  if [ -n "$ebs_dev" ] && [ -b "$ebs_dev" ]; then break; fi
  ebs_dev=
  sleep 1
done
[ -n "$ebs_dev" ] || { echo "EBS data volume ${VOLUME_ID} not found" >&2; exit 1; }

mapfile -t nvmes < <(readlink -f /dev/disk/by-id/nvme-Amazon_EC2_NVMe_Instance_Storage* 2>/dev/null | sort -u)
[ "${#nvmes[@]}" -ge 1 ] || { echo "no instance-store NVMe found" >&2; exit 1; }

# RAID0 the NVMes into one cache device when there is more than one. The cache
# is disposable, so md0 is rebuilt fresh each boot and never persisted.
if [ "${#nvmes[@]}" -gt 1 ]; then
  if [ ! -b /dev/md0 ]; then
    for d in "${nvmes[@]}"; do wipefs -aq "$d"; done
    mdadm --create --verbose /dev/md0 --level=0 --raid-devices="${#nvmes[@]}" "${nvmes[@]}"
  fi
  cache_dev=/dev/md0
else
  cache_dev="${nvmes[0]}"
fi

# Backing device: create the superblock once (persists on EBS), register each boot.
bcache-super-show "$ebs_dev" >/dev/null 2>&1 || make-bcache -B "$ebs_dev"
echo "$ebs_dev" > /sys/fs/bcache/register_quiet || true
for _ in $(seq 1 30); do [ -b /dev/bcache0 ] && break; sleep 1; done
if [ ! -b /dev/bcache0 ]; then
  echo 1 > "/sys/block/$(basename "$ebs_dev")/bcache/running" || true
  for _ in $(seq 1 30); do [ -b /dev/bcache0 ] && break; sleep 1; done
fi
[ -b /dev/bcache0 ] || { echo "bcache0 did not appear" >&2; exit 1; }

# Cache device: recreated fresh whenever nothing is attached. Stop any stale
# registered-but-unattached cache sets first: udev may have auto-registered a
# leftover cache superblock, which keeps the device busy and fails wipefs.
if [ ! -e /sys/block/bcache0/bcache/cache ]; then
  for cset_dir in /sys/fs/bcache/*-*-*-*-*; do
    [ -d "$cset_dir" ] && echo 1 > "$cset_dir/stop" 2>/dev/null
  done
  udevadm settle 2>/dev/null || sleep 1
  wipefs -aq "$cache_dev"
  make-bcache -C "$cache_dev"
  echo "$cache_dev" > /sys/fs/bcache/register_quiet || true
  cset=$(bcache-super-show "$cache_dev" | awk '$1=="cset.uuid"{print $2}')
  for _ in $(seq 1 30); do [ -d "/sys/fs/bcache/$cset" ] && break; sleep 1; done
  echo "$cset" > /sys/block/bcache0/bcache/attach
fi

# Durability is EBS's job; never write-back. Cache sequential IO too since local
# NVMe is far faster than EBS.
echo writethrough > /sys/block/bcache0/bcache/cache_mode
echo 0 > /sys/block/bcache0/bcache/sequential_cutoff

# Mount when already formatted (boot path). First provision formats then mounts
# via the control plane, so a failure here before mkfs is expected and ignored.
mountpoint -q /dat || mount /dat 2>/dev/null || true
