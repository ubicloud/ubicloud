#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require_relative "../../common/lib/util"

config_json = JSON.parse($stdin.read)

cert = config_json["cert"]
cert_key = config_json["cert_key"]
ca_bundle = config_json["ca_bundle"]
user = config_json["admin_user"]
password = config_json["admin_password"]
s3_url = config_json["s3_url"]
s3_bucket = config_json["s3_bucket"]
s3_access_key = config_json["s3_access_key"]
s3_secret_key = config_json["s3_secret_key"]
s3_ca_bundle = config_json["s3_ca_bundle"]

r "mkdir", "-p", "/dat/parseable/staging"
r "chown", "-R", "parseable:parseable", "/dat/parseable"

r "mkdir", "-p", "/etc/parseable/certs/CAs"
r "chown", "-R", "parseable:parseable", "/etc/parseable/"

safe_write_to_file("/etc/parseable/certs/public.crt", cert)
safe_write_to_file("/etc/parseable/certs/private.key", cert_key)
safe_write_to_file("/etc/parseable/certs/CAs/public.crt", ca_bundle)

if s3_ca_bundle
  safe_write_to_file("/etc/parseable/certs/minio-ca.crt", s3_ca_bundle)
end

r "chown", "-R", "parseable:parseable", "/etc/parseable/certs"

s3_ca_env = s3_ca_bundle ? "Environment=SSL_CERT_FILE=/etc/parseable/certs/minio-ca.crt" : ""

parseable_service = <<~PARSEABLE_SERVICE
  [Unit]
  Description=Parseable Log Analytics Server
  After=network.target

  [Service]
  Type=simple
  User=parseable
  Group=parseable
  StartLimitBurst=5
  StartLimitInterval=0
  Restart=on-failure
  RestartSec=1
  Environment=P_USERNAME=#{user}
  Environment=P_PASSWORD=#{password}
  Environment=P_ADDR=[::]:8000
  Environment=P_STAGING_DIR=/dat/parseable/staging
  Environment=P_TLS_CERT_PATH=/etc/parseable/certs/public.crt
  Environment=P_TLS_KEY_PATH=/etc/parseable/certs/private.key
  Environment=P_S3_URL=#{s3_url}
  Environment=P_S3_BUCKET=#{s3_bucket}
  Environment=P_S3_ACCESS_KEY=#{s3_access_key}
  Environment=P_S3_SECRET_KEY=#{s3_secret_key}
  Environment=P_S3_REGION=us-east-1
  Environment=P_S3_PATH_STYLE=true
  #{s3_ca_env}
  ExecStart=/usr/local/bin/parseable s3-store
  ExecStop=/bin/kill -s SIGTERM $MAINPID
  LimitNOFILE=65536
  LimitNPROC=32000

  [Install]
  WantedBy=multi-user.target
PARSEABLE_SERVICE

safe_write_to_file("/etc/systemd/system/parseable.service", parseable_service)
r "systemctl", "daemon-reload"
r "systemctl", "enable", "parseable", "--now"
