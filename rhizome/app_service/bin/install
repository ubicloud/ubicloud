#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../../common/lib/util"

# Install the App Service runtime dependencies on a stock Ubuntu host:
#   - podman: runs the OCI image built from the user's app
#   - pack (Cloud Native Buildpacks CLI): builds the app from source
r "apt-get update"
r "DEBIAN_FRONTEND=noninteractive apt-get install -y podman"

# Cloud Native Buildpacks (`pack`) drive builds through a Docker-API daemon;
# expose podman's socket (unix:///run/podman/podman.sock) so pack can use it.
r "systemctl enable --now podman.socket"

# OpenTelemetry collector, used to forward build + runtime logs to Parseable.
# The "contrib" distribution is required for the journald receiver; pin to a
# version that publishes a contrib .deb (not all releases do, e.g. 0.123.0).
# -f makes curl fail (non-zero) on an HTTP error instead of silently writing an
# error page, which apt would later reject with a confusing "Invalid archive".
otelcol_version = "0.119.0"
r "curl -fsSL --retry 3 https://github.com/open-telemetry/opentelemetry-collector-releases/releases/download/v#{otelcol_version}/otelcol-contrib_#{otelcol_version}_linux_amd64.deb -o /tmp/otelcol.deb"
r "DEBIAN_FRONTEND=noninteractive apt-get install -y /tmp/otelcol.deb"
r "rm -f /tmp/otelcol.deb"

pack_version = ARGV.shift || "0.36.4"
r "curl -fsSL --retry 3 https://github.com/buildpacks/pack/releases/download/v#{pack_version}/pack-v#{pack_version}-linux.tgz -o /tmp/pack.tgz"
r "tar -C /usr/local/bin --no-same-owner -xzf /tmp/pack.tgz pack"
r "rm -f /tmp/pack.tgz"
