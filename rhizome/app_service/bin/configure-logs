#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../../common/lib/util"
require "json"
require "yaml"
require "fileutils"

# Configure the OpenTelemetry collector to forward this server's build and
# runtime logs to the app's stream on the shared Parseable instance.
#
# Build logs come from the deploy daemon (journald unit deploy_app); runtime
# logs come from the app's podman container (journald log driver, tagged with
# CONTAINER_NAME). Each pipeline tags its logs with a `source` attribute
# (build/runtime) so the UI can filter them.
config = JSON.parse($stdin.read)
container_name = "app-#{config["process_type"] || "web"}"
otlp = (config["log_destinations"] || []).find { |d| d["type"] == "otlp" }

# Nothing to do when no managed destination is configured (e.g. Parseable off).
if otlp.nil?
  puts "no log destination configured"
  exit 0
end

headers = otlp.dig("options", "headers") || {}
if (ca_bundle = otlp.dig("options", "ca_bundle"))
  File.write("/etc/otelcol-contrib/parseable-ca.pem", ca_bundle)
end

# Build the collector config as a structure and serialize it, rather than
# hand-indenting YAML -- multi-line interpolation (headers, tls) is too easy to
# misindent, which makes otelcol fail to load its config and crash-loop.
otel_config = {
  "receivers" => {
    "journald/build" => {"units" => ["deploy_app"]},
    "journald/runtime" => {"matches" => [{"CONTAINER_NAME" => container_name}]},
  },
  "processors" => {
    "resource/build" => {"attributes" => [{"key" => "source", "value" => "build", "action" => "insert"}]},
    "resource/runtime" => {"attributes" => [{"key" => "source", "value" => "runtime", "action" => "insert"}]},
    "resource/app" => {"attributes" => [
      {"key" => "instance", "value" => config["instance"], "action" => "insert"},
      {"key" => "resource_id", "value" => config["resource_id"], "action" => "insert"},
    ]},
  },
  "exporters" => {
    "otlphttp/parseable" => {
      "logs_endpoint" => "#{otlp["url"]}/v1/logs",
      "encoding" => "json",
      "headers" => headers,
      "tls" => ca_bundle ? {"ca_file" => "/etc/otelcol-contrib/parseable-ca.pem"} : {"insecure" => true},
    },
  },
  "service" => {
    "pipelines" => {
      "logs/build" => {"receivers" => ["journald/build"], "processors" => ["resource/build", "resource/app"], "exporters" => ["otlphttp/parseable"]},
      "logs/runtime" => {"receivers" => ["journald/runtime"], "processors" => ["resource/runtime", "resource/app"], "exporters" => ["otlphttp/parseable"]},
    },
  },
}

File.write("/etc/otelcol-contrib/config.yaml", otel_config.to_yaml)

# The collector runs as its own (non-root) user, so grant it read access to the
# system journal where the build (deploy_app) and runtime (podman) logs live.
FileUtils.mkdir_p("/etc/systemd/system/otelcol-contrib.service.d")
File.write("/etc/systemd/system/otelcol-contrib.service.d/journal.conf", "[Service]\nSupplementaryGroups=systemd-journal\n")
r "systemctl", "daemon-reload"

r "systemctl", "enable", "--now", "otelcol-contrib"
r "systemctl", "restart", "otelcol-contrib"
