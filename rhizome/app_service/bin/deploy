#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../../common/lib/util"
require "json"
require "net/http"
require "uri"
require "fileutils"

# Build and run a deployment in place on a persistent app server.
#
#   deploy <repo_url> <branch> <commit_sha> <secret_store_ubid> <api_url> [process_type] [db_config_json]
#
# api_url is the control-plane API the VM calls back to (for secrets / DB certs).
#
# Steps:
#   1. Pull config/secrets from the app's Secret Store, authenticating with this
#      VM's managed identity token (served by the instance metadata endpoint).
#   2. Clone the repo at the pinned commit into a fresh release directory.
#   3. Build an OCI image from source with Cloud Native Buildpacks (`pack`),
#      with the config/secrets available as build-time env.
#   4. Run the image with podman (new container alongside the old), then swap.
repo_url, branch, commit_sha, secret_store_ubid, api_url, process_type, db_config_json = ARGV
process_type ||= "web"
fail "usage: deploy <repo_url> <branch> <commit_sha> <secret_store_ubid> <api_url> [process_type] [db_config_json]" unless repo_url && branch && commit_sha && secret_store_ubid && api_url

# This runs as a transient systemd unit (via daemonizer2) with a minimal
# environment, so set what the build/runtime tools need: HOME (pack and git read
# config from it) and DOCKER_HOST so pack and podman talk to the rootful podman
# API socket (enabled by bin/install).
ENV["HOME"] ||= "/root"
ENV["DOCKER_HOST"] ||= "unix:///run/podman/podman.sock"

# 1. Managed-identity token + config/secrets. The token is served by the per-VM
# metadata endpoint, which listens on a well-known IPv6 link address inside the
# VM's network (not the AWS-style 169.254.169.254 IPv4 address).
token = Net::HTTP.get(URI("http://[FD00:0B1C:100D:5AFE:CE::]/identity/token")).strip
project_ubid, store_path = secret_store_ubid, "/secret-store/#{secret_store_ubid}/secret"
env = {}
begin
  uri = URI("#{api_url}/project/#{project_ubid}#{store_path}")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = uri.scheme == "https"
  keys = JSON.parse(http.get(uri.request_uri, {"Authorization" => "Bearer #{token}"}).body)["items"] || []
  keys.each do |item|
    one = URI("#{uri}/#{item["key"]}")
    body = JSON.parse(http.get(one.request_uri, {"Authorization" => "Bearer #{token}"}).body)
    env[item["key"]] = body["value"]
  end
rescue => ex
  warn "failed to fetch secrets: #{ex.message}"
end

# 1b. Attached database: download the cert-auth role's client cert with this VM's
# managed identity and expose PG* connection env (no stored credential).
db_dir = "/home/ubi/app_service/db"
if db_config_json
  db = JSON.parse(db_config_json)
  FileUtils.mkdir_p(db_dir)
  File.write("#{db_dir}/ca.crt", db["ca"])
  cert_uri = URI("#{api_url}#{db["cert_url"]}")
  cert_http = Net::HTTP.new(cert_uri.host, cert_uri.port)
  cert_http.use_ssl = cert_uri.scheme == "https"
  bundle = cert_http.get(cert_uri.request_uri, {"Authorization" => "Bearer #{token}"}).body
  File.write("#{db_dir}/client.crt", bundle[/-----BEGIN CERTIFICATE-----.*?-----END CERTIFICATE-----/m].to_s)
  File.write("#{db_dir}/client.key", bundle[/-----BEGIN[^-]*PRIVATE KEY-----.*?-----END[^-]*PRIVATE KEY-----/m].to_s)
  File.chmod(0o600, "#{db_dir}/client.key")
  env.merge!(
    "PGHOST" => db["host"], "PGPORT" => db["port"].to_s, "PGDATABASE" => db["dbname"], "PGUSER" => db["user"],
    "PGSSLMODE" => "verify-full",
    "PGSSLROOTCERT" => "#{db_dir}/ca.crt", "PGSSLCERT" => "#{db_dir}/client.crt", "PGSSLKEY" => "#{db_dir}/client.key",
  )
end

release_dir = "/home/ubi/app_service/releases/#{commit_sha}"
FileUtils.rm_rf(release_dir)
FileUtils.mkdir_p(release_dir)

# Never block on a credential prompt: if GitHub denies anonymous access (private
# repo / wrong URL) git would try to read a username from a tty that doesn't
# exist here, failing with a confusing "could not read Username". This makes it
# fail fast with the real reason instead.
ENV["GIT_TERMINAL_PROMPT"] = "0"

# 2. Clone the pinned commit.
r "git", "clone", "--depth", "1", "--branch", branch, repo_url, release_dir
r "git", "-C", release_dir, "fetch", "--depth", "1", "origin", commit_sha
r "git", "-C", release_dir, "checkout", commit_sha

# 3. Build with buildpacks.
image = "app-#{commit_sha[0, 12]}"
build_env = env.flat_map { |k, v| ["--env", "#{k}=#{v}"] }
r "pack", "build", image, "--path", release_dir, "--builder", "heroku/builder:24", *build_env

# 4. Run the process for this server's type and swap. Web servers publish the
# web port (the per-app load balancer forwards to it); other process types
# (e.g. worker) run headless, executing their named Procfile process.
run_env = env.flat_map { |k, v| ["--env", "#{k}=#{v}"] }
container = "app-#{process_type}"
port_args = (process_type == "web") ? ["-p", "8080:8080"] : []
launch_args = (process_type == "web") ? [] : [process_type]
db_mount = db_config_json ? ["-v", "#{db_dir}:#{db_dir}:ro"] : []
r "podman", "rm", "-f", container, "||", "true"
r "podman", "run", "-d", "--name", container, "--restart", "always", *port_args, *db_mount, *run_env, image, *launch_args
