{
  "name": "Clickgres",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/ubicloud",
  "features": {},
  "forwardPorts": [
    3000
  ],
  "portsAttributes": {
    "3000": {
      "label": "Ubicloud Web",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "",
  "postStartCommand": "",
  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp",
        "rebornix.Ruby",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "ruby.useBundler": true,
        "[ruby]": {
          "editor.defaultFormatter": "Shopify.ruby-lsp"
        }
      }
    }
  },
  "remoteUser": "vscode"
}