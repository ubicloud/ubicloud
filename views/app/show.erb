<%
tabs = [
  ["Overview", "overview", "hero-squares-plus"],
  ["Deployments", "deployments", "hero-rocket-launch"],
  ["Processes", "processes", "hero-server-stack"],
  ["Config", "config", "hero-document-text"],
  ["Database", "database", "hero-circle-stack"],
  ["Logs", "logs", "hero-chat-bubble-bottom-center-text"],
  ["Settings", "settings", "hero-cog-8-tooth"]
]

active = tabs.find { |_label, page, _icon| page == @page }
@page_title = (@page == "overview") ? @app_resource.name : "#{@app_resource.name} - #{active[0]}"
%>

<%== part(
  "object/show",
  object: @app_resource,
  tabs:,
  type: "app",
  breadcrumb_label: "Apps",
  right_header: part("components/app_state_label", state: @app_resource.display_state, extra_class: "text-md")
) %>
