<% @page_title = @app_resource.name
back = "#{@project.path}/app"
app_path = path(@app_resource)
can_edit = has_permission?("AppResource:edit", @app_resource.id)
can_delete = has_permission?("AppResource:delete", @app_resource.id)
deployments = @app_resource.deployments_dataset.reverse(:version).all %>

<%== part(
  "components/page_header",
  title: @app_resource.name,
  back:,
  right_items: [
    part("components/button", text: "Logs", link: "#{app_path}/logs", extra_class: "mr-2"),
    (can_delete ? part("components/delete_button", text: "Delete app", confirmation: @app_resource.name, url: app_path) : nil)
  ].compact,
  breadcrumbs: [
    %w[Projects /project],
    [@project.name, @project.path],
    ["Apps", back],
    [@app_resource.name, "#"]
  ]
) %>

<div class="grid gap-6">
  <% if can_edit %>
    <div class="flex justify-end">
      <% form(action: "#{app_path}/deploy", method: :post) do %>
        <%== part("components/form/submit_button", text: "Deploy") %>
      <% end %>
    </div>
  <% end %>

  <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg font-semibold leading-6 text-gray-900">Overview</h3>
    </div>
    <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
      <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-gray-500">State</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @app_resource.display_state %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">URL</dt>
          <dd class="mt-1 text-sm text-gray-900">
            <% if @app_resource.hostname %>
              <a class="text-orange-600" href="http://<%= @app_resource.hostname %>">http://<%= @app_resource.hostname %></a>
            <% else %>
              &mdash;
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Repository</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @app_resource.repo_url %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Branch</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @app_resource.branch %></dd>
        </div>
      </dl>
    </div>
  </div>

  <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg font-semibold leading-6 text-gray-900">Deployments</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="pl-4 pr-3 sm:pl-6 py-3.5 text-left text-sm font-semibold text-gray-900">Version</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Commit</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% deployments.each do |d| %>
            <tr id="deployment-<%= d.ubid %>">
              <td class="pl-4 pr-3 sm:pl-6 py-4 text-sm font-medium text-gray-900">v<%= d.version %></td>
              <td class="px-3 py-4 text-sm text-gray-500"><%= d.commit_sha ? d.commit_sha[0, 12] : "—" %></td>
              <td class="px-3 py-4 text-sm text-gray-500"><%= d.status %></td>
            </tr>
          <% end %>
          <% if deployments.empty? %>
            <tr><td colspan="3" class="text-center py-6 text-sm text-gray-500">No deployments yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg font-semibold leading-6 text-gray-900">Processes</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="pl-4 pr-3 sm:pl-6 py-3.5 text-left text-sm font-semibold text-gray-900">Type</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Replicas</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">VM size</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @app_resource.processes.each do |p| %>
            <tr id="process-<%= p.process_type %>">
              <td class="pl-4 pr-3 sm:pl-6 py-4 text-sm font-medium text-gray-900"><%= p.process_type %></td>
              <td class="px-3 py-4 text-sm text-gray-500"><%= p.replica_count %></td>
              <td class="px-3 py-4 text-sm text-gray-500"><%= p.vm_size %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if can_edit %>
      <div class="px-4 py-5 sm:p-6 border-t border-gray-200">
        <h4 class="text-sm font-semibold text-gray-900 mb-3">Scale a process</h4>
        <% form(action: "#{app_path}/scale", method: :post) do %>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-4 sm:items-end">
            <%== part("components/form/text", name: "process_type", label: "Process", value: "web", attributes: {required: true}) %>
            <%== part("components/form/text", name: "replica_count", label: "Replicas", type: "number", value: "1", attributes: {min: 1, required: true}) %>
            <%== part("components/form/text", name: "vm_size", label: "VM size", attributes: {placeholder: "standard-2"}) %>
            <%== part("components/form/submit_button", text: "Scale") %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if can_edit %>
    <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-semibold leading-6 text-gray-900">Settings</h3>
      </div>
      <div class="px-4 py-5 sm:p-6">
        <% form(action: app_path, method: :post) do %>
          <div class="grid grid-cols-1 gap-6">
            <%== part("components/form/text", name: "repo_url", label: "GitHub repository URL", value: @app_resource.repo_url, attributes: {required: true}) %>
            <%== part("components/form/text", name: "branch", label: "Branch", value: @app_resource.branch, attributes: {required: true}) %>
            <div class="flex justify-end">
              <%== part("components/form/submit_button", text: "Save") %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
