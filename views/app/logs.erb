<% @page_title = "#{@app_resource.name} - Logs"
back = path(@app_resource) %>

<%== part(
  "components/page_header",
  title: "Logs",
  back:,
  breadcrumbs: [
    %w[Projects /project],
    [@project.name, @project.path],
    ["Apps", "#{@project.path}/app"],
    [@app_resource.name, back],
    ["Logs", "#"]
  ]
) %>

<div class="grid gap-6">
  <div class="flex gap-2">
    <% [["All", nil], ["Build", "build"], ["Runtime", "runtime"]].each do |label, src| %>
      <a href="<%= "#{back}/logs#{"?source=#{src}" if src}" %>" class="<%= (@source == src) ? "bg-orange-600 text-white" : "bg-white text-gray-700 ring-1 ring-gray-300" %> rounded-md px-3 py-1.5 text-sm font-semibold">
        <%= label %>
      </a>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="pl-4 pr-3 sm:pl-6 py-3.5 text-left text-sm font-semibold text-gray-900">Time</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Source</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Severity</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Message</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @logs.each do |log| %>
            <tr>
              <td class="pl-4 pr-3 sm:pl-6 py-2 text-sm text-gray-500 whitespace-nowrap"><%= log[:timestamp] %></td>
              <td class="px-3 py-2 text-sm text-gray-500"><%= log[:source] %></td>
              <td class="px-3 py-2 text-sm text-gray-500"><%= log[:severity] %></td>
              <td class="px-3 py-2 text-sm font-mono text-gray-900"><%= log[:message] %></td>
            </tr>
          <% end %>
          <% if @logs.empty? %>
            <tr><td colspan="4" class="text-center py-6 text-sm text-gray-500">No logs in the last 30 minutes (or log aggregation is not enabled).</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
