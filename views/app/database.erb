<%
app = @app_resource
app_path = path(app)
can_edit = has_permission?("AppResource:edit", app.id)
db = app.database_connection
%>

<div class="pt-6 space-y-6">
  <% if db %>
    <div class="rounded-lg border border-gray-200">
      <div class="flex items-start justify-between gap-4 border-b border-gray-200 px-5 py-4">
        <div class="flex items-center gap-3">
          <span class="rounded-md bg-orange-50 p-2 text-orange-600"><%== part("components/icon", name: "hero-circle-stack", classes: "h-6 w-6") %></span>
          <div>
            <h3 class="text-base font-semibold text-gray-900">Managed PostgreSQL</h3>
            <div class="mt-0.5"><%== part("components/app_state_label", state: db[:state]) %></div>
          </div>
        </div>
        <% if can_edit %>
          <%== part("components/delete_button", text: "Detach database", confirmation: app.name, url: "#{app_path}/database") %>
        <% end %>
      </div>

      <dl class="grid grid-cols-1 gap-x-6 gap-y-5 px-5 py-5 sm:grid-cols-2">
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-gray-500">Name</dt>
          <dd class="mt-1 break-all font-mono text-sm text-gray-900"><%= db[:name] %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-gray-500">Database</dt>
          <dd class="mt-1 font-mono text-sm text-gray-900"><%= db[:database] %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-gray-500">User</dt>
          <dd class="mt-1 font-mono text-sm text-gray-900"><%= db[:user] %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium uppercase tracking-wide text-gray-500">Port</dt>
          <dd class="mt-1 font-mono text-sm text-gray-900"><%= db[:port] %></dd>
        </div>
      </dl>
    </div>
  <% else %>
    <%== part(
      "components/empty_state",
      icon: "hero-circle-stack",
      title: "No database attached",
      description: "Create a managed PostgreSQL for this app. It is provisioned alongside the app and connects automatically via the app's managed identity — no credentials to manage."
    ) %>
    <% if can_edit %>
      <div class="flex justify-center">
        <% form(action: "#{app_path}/database", method: :post) do %>
          <%== part("components/form/submit_button", text: "Create database", icon: "hero-circle-stack") %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
