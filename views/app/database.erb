<% @page_title = "#{@app_resource.name} - Database"
back = path(@app_resource)
can_edit = has_permission?("AppResource:edit", @app_resource.id)
db = @app_resource.database_connection %>

<%== part(
  "components/page_header",
  title: "Database",
  back:,
  right_items: ((can_edit && db) ? [part("components/delete_button", text: "Detach database", confirmation: @app_resource.name, url: "#{back}/database")] : []),
  breadcrumbs: [
    %w[Projects /project],
    [@project.name, @project.path],
    ["Apps", "#{@project.path}/app"],
    [@app_resource.name, back],
    ["Database", "#"]
  ]
) %>

<div class="grid gap-6">
  <% if db %>
    <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
      <div class="px-4 py-5 sm:px-6">
        <h3 class="text-lg font-semibold leading-6 text-gray-900">Managed PostgreSQL</h3>
        <p class="mt-1 text-sm text-gray-500">The app connects automatically using its managed identity (no password is stored). Connection details are exposed to the app as <code>PG*</code> environment variables.</p>
      </div>
      <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
        <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
          <div><dt class="text-sm font-medium text-gray-500">State</dt><dd class="mt-1 text-sm text-gray-900"><%= db[:state] %></dd></div>
          <div><dt class="text-sm font-medium text-gray-500">Name</dt><dd class="mt-1 text-sm text-gray-900"><%= db[:name] %></dd></div>
          <div><dt class="text-sm font-medium text-gray-500">Database</dt><dd class="mt-1 text-sm text-gray-900"><%= db[:database] %></dd></div>
          <div><dt class="text-sm font-medium text-gray-500">User</dt><dd class="mt-1 text-sm text-gray-900"><%= db[:user] %></dd></div>
          <div><dt class="text-sm font-medium text-gray-500">Port</dt><dd class="mt-1 text-sm text-gray-900"><%= db[:port] %></dd></div>
        </dl>
      </div>
    </div>
  <% else %>
    <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
      <div class="px-4 py-8 sm:p-10 text-center">
        <p class="text-sm text-gray-500 mb-4">No database attached. Create a managed PostgreSQL for this app — it connects automatically via the app's managed identity.</p>
        <% if can_edit %>
          <% form(action: "#{back}/database", method: :post) do %>
            <%== part("components/form/submit_button", text: "Create database") %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
