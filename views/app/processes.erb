<%
app = @app_resource
app_path = path(app)
can_edit = has_permission?("AppResource:edit", app.id)
processes = app.processes_dataset.order(:process_type).all
vm_size_options = AppResource.vm_size_options.map { [it, it] }
col_count = can_edit ? 4 : 3
%>

<div class="pt-6 space-y-6">
  <% if can_edit %>
    <%# One scale form per process, associated with its row's inputs via the
        HTML form= attribute so each row saves independently. %>
    <div hidden>
      <% processes.each do |p| %>
        <% form(action: "#{app_path}/scale", method: :post, id: "scale-#{p.process_type}") do %>
          <%== hidden_inputs(process_type: p.process_type) %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <p class="max-w-2xl text-sm text-gray-500">
    Each process type runs on its own dedicated, persistent VMs. <span class="font-medium text-gray-900">web</span> processes
    receive traffic from the load balancer; other types (e.g. <span class="font-medium text-gray-900">worker</span>) run headless.
  </p>

  <div class="overflow-hidden rounded-lg border border-gray-200">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Process</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Replicas</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">VM size</th>
            <% if can_edit %>
              <th scope="col" class="py-3.5 pr-4 sm:pr-6"><span class="sr-only">Actions</span></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% processes.each do |p| %>
            <tr id="process-<%= p.process_type %>">
              <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6">
                <span class="inline-flex items-center gap-2">
                  <%== part("components/icon", name: p.web? ? "hero-globe-alt" : "hero-cpu-chip", classes: "h-5 w-5 text-gray-400") %>
                  <%= p.process_type %>
                </span>
              </td>
              <% if can_edit %>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                  <div class="w-24">
                    <%== part("components/form/text", name: "replica_count", id: "replica_count-#{p.process_type}", type: "number", value: p.replica_count, attributes: {min: 1, required: true, form: "scale-#{p.process_type}"}) %>
                  </div>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                  <div class="w-44">
                    <%== part("components/form/select", name: "vm_size", id: "vm_size-#{p.process_type}", options: vm_size_options, selected: p.vm_size, attributes: {form: "scale-#{p.process_type}"}) %>
                  </div>
                </td>
                <td class="whitespace-nowrap py-4 pr-4 text-right text-sm sm:pr-6">
                  <%== part("components/form/submit_button", text: "Save", attributes: {form: "scale-#{p.process_type}"}) %>
                </td>
              <% else %>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= p.replica_count %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= p.vm_size %></td>
              <% end %>
            </tr>
          <% end %>
          <% if processes.empty? %>
            <tr><td colspan="<%= col_count %>" class="px-6 py-10 text-center text-sm text-gray-500">No processes yet. They are discovered from your Procfile on the next deploy.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
