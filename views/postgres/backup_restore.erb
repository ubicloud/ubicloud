<% min_date = @pg.timeline.earliest_restore_time
max_date = @pg.timeline.latest_restore_time %>

<% if min_date && max_date > min_date %>
  <div class="p-6">
    <% form(action: "#{path(@pg)}/restore", method: :post) do %>
      <div class="space-y-4">
        <div>
          <h3 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-2xl sm:tracking-tight">Fork PostgreSQL database</h3>
          <p class="mt-1 text-sm text-gray-500">
            When you fork your existing PostgreSQL database, a new server will be provisioned.
          </p>
        </div>
        <div class="grid grid-cols-12 gap-6">
          <div class="col-span-12 sm:col-span-5">
            <%== part("components/form/text", label: "New server name", name: "name", attributes: { placeholder: @pg.name + "-fork", required: true }) %>
          </div>
          <div class="col-span-12 sm:col-span-5">
            <%== part("components/form/datepicker", label: "Target Time (UTC)", name: "restore_target", default_date: max_date, max_date:, min_date:) %>
          </div>
          <div class="col-span-12 sm:col-span-2 flex justify-end items-end">
            <%== part("components/form/submit_button", text: "Fork") %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="p-6">
    <div class="text-gray-500">
      No backups available for this PostgreSQL database.
    </div>
  </div>
<% end %>

<div class="p-6">
  <div class="md:flex md:items-center md:justify-between pb-2 lg:pb-4">
    <div class="min-w-0 flex-1">
      <h3 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-2xl sm:tracking-tight">Backup Download Access</h3>
      <p class="mt-1 text-sm text-gray-500">
        Get temporary, read-only credentials to download your backups directly with <code>aws</code>, <code>mc</code>, or <code>wal-g</code>.
      </p>
    </div>
  </div>

  <% if @pg.read_replica? %>
    <div class="text-gray-500">
      Backup download credentials are managed on the primary database. See <a href="<%= path(@pg.parent) %>/backup-restore" class="text-orange-600 hover:underline">its Backup/Restore tab</a>.
    </div>
  <% elsif !@pg.location.aws? && !@project.get_ff_postgres_backup_download_minio %>
    <div class="text-gray-500">
      Backup downloads are not yet enabled for this project's PostgreSQL databases on this location.
    </div>
  <% else %>
    <button type="button" class="get-backup-credentials-btn rounded-md bg-orange-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-orange-500" data-url="<%= "#{path(@pg)}/backup-credentials" %>">
      Get download credentials
    </button>

    <div id="backup-credentials-panel" class="hidden bg-gray-200 rounded-md p-6 mt-5 space-y-3">
      <div class="flex items-center gap-2">
        <span class="font-semibold">Bucket:</span> <%== part("components/copyable_content", content: "", classes: "backup-credentials-bucket") %>
      </div>
      <div class="flex items-center gap-2">
        <span class="font-semibold">Endpoint:</span> <%== part("components/copyable_content", content: "", classes: "backup-credentials-endpoint") %>
      </div>
      <div class="flex items-center gap-2">
        <span class="font-semibold">Region:</span> <%== part("components/copyable_content", content: "", classes: "backup-credentials-region") %>
      </div>
      <div class="flex items-center gap-2">
        <span class="font-semibold">Access Key ID:</span> <%== part("components/copyable_content", content: "", classes: "backup-credentials-access-key") %>
      </div>
      <div class="flex items-center gap-2">
        <span class="font-semibold">Secret Access Key:</span> <%== part("components/copyable_content", content: "", revealable: true, classes: "backup-credentials-secret-key") %>
      </div>
      <div class="flex items-center gap-2">
        <span class="font-semibold">Session Token:</span> <%== part("components/copyable_content", content: "", revealable: true, classes: "backup-credentials-session-token") %>
      </div>
      <div class="flex items-center gap-2">
        <span class="font-semibold">Expires at:</span> <span class="backup-credentials-expiration"></span>
      </div>

      <div class="pt-2">
        <div class="flex items-center gap-2">
          Example:
          <select class="backup-credentials-tool-select rounded-md border-gray-300 text-sm">
            <option value="aws">aws s3 sync</option>
            <option value="mc">mc mirror</option>
            <option value="walg">wal-g env</option>
          </select>
        </div>
        <pre class="backup-credentials-example mt-2 whitespace-pre-wrap break-all rounded-md bg-gray-800 text-gray-100 text-xs p-3"></pre>
      </div>
    </div>
  <% end %>
</div>

<% backups = @pg.timeline.backups %>
<% if backups.count > 0 %>
  <div class="p-6">
    <div class="md:flex md:items-center md:justify-between pb-2 lg:pb-4">
      <div class="min-w-0 flex-1">
        <h3 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-2xl sm:tracking-tight">Backups</h3>
      </div>
    </div>

    <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white divide-y divide-gray-200">
      <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Backup Time</th>
            <th scope="col" class="py-3.5 text-left text-sm font-semibold text-gray-900">Type</th>
            <th scope="col" class="py-3.5 text-left text-sm font-semibold text-gray-900">Fork</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% backups.each do %>
            <% target_time = Time.at((it.last_modified.to_i / 60.0).ceil * 60) %>
            <tr>
              <td class="py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6"><%= target_time %></td>
              <td class="py-4 text-sm font-medium text-gray-900">Full Backup</td>
              <td class="py-4 text-sm font-medium text-gray-900">
                <div class="cursor-pointer fork-icon" data-target-datetime="<%= target_time %>">
                  <%== part("components/icon", name: "fork", classes: "text-black-600 h-6 w-6") %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
