<% @page_title = "Database Migration" %>

<%== part(
  "components/page_header",
  breadcrumbs: [
    %w[Projects /project],
    [@project.name, @project.path],
    ["PostgreSQL Databases", "#{@project.path}/postgres"],
    [@pg.name, "#{@project.path}#{@pg.path}"],
    %w[Migration #]
  ]
) %>

<%
  migration_phases = [
    ["discovering", "Discovering source databases"],
    ["preparing_client_vm", "Preparing migration environment"],
    ["plan_ready", "Migration plan ready"],
    ["creating_target", "Creating target database"],
    ["migrating", "Migrating data"],
    ["verifying", "Verifying migration"],
    ["completed", "Migration completed"]
  ]

  current_found = false
  phase_progress = migration_phases.map do |phase_key, phase_label|
    if @migration.status == "failed" || @migration.status == "cancelled"
      status = "pending"
    elsif current_found
      status = "pending"
    elsif phase_key == @migration.status
      current_found = true
      status = "running"
    else
      status = current_found ? "pending" : "done"
    end
    [phase_key, phase_label, status]
  end

  # Recalculate: mark all before current as done
  phase_progress = migration_phases.each_with_object([]) do |(phase_key, phase_label), arr|
    if @migration.status == phase_key
      arr.each { |item| item[2] = "done" }
      arr << [phase_key, phase_label, "running"]
    else
      arr << [phase_key, phase_label, arr.any? { |i| i[2] == "running" } ? "pending" : "done"]
    end
  end

  if ["failed", "cancelled"].include?(@migration.status)
    phase_progress = migration_phases.map { |k, l| [k, l, "pending"] }
  end

  if @migration.status == "completed"
    phase_progress = migration_phases.map { |k, l| [k, l, "done"] }
  end
%>

<div class="grid gap-6">
  <% if @migration.status == "discovering" || @migration.status == "preparing_client_vm" %>
    <!-- Discovering / Preparing -->
    <div class="auto-refresh hidden" data-interval="10"></div>

    <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center space-x-3">
          <%== part("components/icon", name: "hero-refresh", classes: "h-6 w-6 text-orange-500 animate-spin") %>
          <div>
            <h3 class="text-base font-semibold leading-7 text-gray-900">Analyzing Source Database...</h3>
            <p class="mt-1 text-sm text-gray-600">
              Connecting to your source database and discovering schemas, tables, and sizes.
              This may take a few minutes depending on the size of your database.
            </p>
          </div>
        </div>

        <!-- Phase stepper -->
        <div class="mt-6">
          <% phase_progress.each do |phase_key, phase_label, status| %>
            <div class="flex items-center space-x-3 py-2">
              <% if status == "done" %>
                <%== part("components/icon", name: "hero-check", classes: "h-5 w-5 text-green-500") %>
              <% elsif status == "running" %>
                <%== part("components/icon", name: "hero-refresh", classes: "h-5 w-5 text-orange-500 animate-spin") %>
              <% else %>
                <%== part("components/icon", name: "hero-ellipsis-horizontal", classes: "h-5 w-5 text-gray-300") %>
              <% end %>
              <span class="text-sm <%= status == 'running' ? 'font-semibold text-gray-900' : 'text-gray-500' %>"><%= phase_label %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

  <% elsif @migration.status == "plan_ready" %>
    <!-- Plan Ready — show discovered databases and configuration form -->
    <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
      <div class="px-4 py-5 sm:p-6">
        <div>
          <h3 class="text-base font-semibold leading-7 text-gray-900">Source Database Analysis Complete</h3>
          <p class="mt-1 text-sm text-gray-600">
            We found the following databases on your source server. Select the databases you want to migrate
            and configure your target environment.
          </p>
        </div>
      </div>
    </div>

    <% form(action: "#{@project.path}#{@pg.path}/migration/#{@migration.ubid}/start", method: :post) do %>
      <!-- Discovered databases table -->
      <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-base font-semibold leading-6 text-gray-900">Databases to Migrate</h3>
          <div class="mt-4 overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-300">
              <thead>
                <tr>
                  <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">
                    <input type="checkbox" id="select-all-dbs" class="rounded border-gray-300 text-orange-600 focus:ring-orange-600">
                  </th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Database</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Size</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Tables</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 bg-white">
                <% @migration.discovered_databases.each do |db| %>
                  <tr>
                    <td class="whitespace-nowrap py-4 pl-4 pr-3 sm:pl-6">
                      <input type="checkbox" name="databases[]" value="<%= db[:name] %>" class="db-checkbox rounded border-gray-300 text-orange-600 focus:ring-orange-600" checked>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm font-medium text-gray-900"><%= db[:name] %></td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= db[:size] %></td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= db[:table_count] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Target configuration -->
      <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white mt-6">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-base font-semibold leading-7 text-gray-900">Target Configuration</h3>
          <p class="mt-1 text-sm leading-6 text-gray-600">
            Configure the target PostgreSQL database on Ubicloud.
          </p>

          <div class="mt-6 grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-6">
            <div class="sm:col-span-3">
              <%== part("components/form/select",
                name: "location",
                label: "Location",
                options: @migration.available_locations.map { |loc| [loc, loc] },
                selected: @migration.default_location,
                attributes: { required: "required" }
              ) %>
            </div>

            <div class="sm:col-span-3">
              <%== part("components/form/select",
                name: "size",
                label: "Server Size",
                options: @migration.available_sizes.map { |s| [s, s] },
                selected: @migration.recommended_size,
                attributes: { required: "required" }
              ) %>
            </div>

            <div class="sm:col-span-3">
              <%== part("components/form/select",
                name: "storage_size",
                label: "Storage Size",
                options: @migration.available_storage_sizes.map { |s| [s, s] },
                selected: @migration.recommended_storage_size,
                attributes: { required: "required" }
              ) %>
            </div>

            <div class="sm:col-span-3">
              <%== part("components/form/select",
                name: "version",
                label: "PostgreSQL Version",
                options: @migration.available_versions.map { |v| [v, "PostgreSQL #{v}"] },
                selected: @migration.source_version,
                attributes: { required: "required" }
              ) %>
            </div>
          </div>
        </div>

        <div class="border-t border-gray-200 px-4 py-4 sm:px-6">
          <div class="flex items-center justify-end gap-x-6">
            <a href="<%= @project.path %><%= @pg.path %>" class="text-sm font-semibold leading-6 text-gray-900">Cancel</a>
            <%== part("components/form/submit_button", text: "Start Migration") %>
          </div>
        </div>
      </div>
    <% end %>

  <% elsif ["creating_target", "migrating", "verifying"].include?(@migration.status) %>
    <!-- Migration in progress -->
    <div class="auto-refresh hidden" data-interval="10"></div>

    <!-- Phase stepper -->
    <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-base font-semibold leading-7 text-gray-900">Migration In Progress</h3>
        <p class="mt-1 text-sm text-gray-600">
          Your data is being migrated to Ubicloud. This process may take a while depending on the size of your databases.
        </p>

        <div class="mt-6">
          <% phase_progress.each do |phase_key, phase_label, status| %>
            <div class="flex items-center space-x-3 py-2">
              <% if status == "done" %>
                <%== part("components/icon", name: "hero-check", classes: "h-5 w-5 text-green-500") %>
              <% elsif status == "running" %>
                <%== part("components/icon", name: "hero-refresh", classes: "h-5 w-5 text-orange-500 animate-spin") %>
              <% else %>
                <%== part("components/icon", name: "hero-ellipsis-horizontal", classes: "h-5 w-5 text-gray-300") %>
              <% end %>
              <span class="text-sm <%= status == 'running' ? 'font-semibold text-gray-900' : 'text-gray-500' %>"><%= phase_label %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Per-database progress table -->
    <% if @migration.database_statuses&.any? %>
      <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-base font-semibold leading-6 text-gray-900">Database Progress</h3>
          <div class="mt-4 overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-300">
              <thead>
                <tr>
                  <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Database</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Status</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Progress</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Tables Migrated</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 bg-white">
                <% @migration.database_statuses.each do |db_status| %>
                  <tr>
                    <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6"><%= db_status[:name] %></td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                      <%== part("components/state_label",
                        state: db_status[:status],
                        color: case db_status[:status]
                          when "completed" then "bg-green-100 text-green-800"
                          when "migrating" then "bg-blue-100 text-blue-800"
                          when "failed" then "bg-red-100 text-red-800"
                          else "bg-gray-100 text-gray-800"
                          end
                      ) %>
                    </td>
                    <td class="px-3 py-4 text-sm text-gray-500" style="min-width: 200px;">
                      <% progress_pct = db_status[:total_tables].to_i.zero? ? 0 : (100 * db_status[:migrated_tables].to_i / db_status[:total_tables].to_i) %>
                      <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-orange-500 h-2 rounded-full" style="width: <%= progress_pct %>%"></div>
                      </div>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                      <%= db_status[:migrated_tables] %>/<%= db_status[:total_tables] %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Cancel button -->
    <div class="flex justify-end">
      <% form(action: "#{@project.path}#{@pg.path}/migration/#{@migration.ubid}/cancel", method: :post) do %>
        <button type="submit" class="inline-flex items-center justify-center rounded-md px-3 py-2 text-sm font-semibold text-white shadow-sm bg-red-600 hover:bg-red-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600"
          onclick="return confirm('Are you sure you want to cancel this migration? Data already migrated will not be rolled back.');">
          Cancel Migration
        </button>
      <% end %>
    </div>

  <% elsif @migration.status == "completed" %>
    <!-- Completed -->
    <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center space-x-3">
          <%== part("components/icon", name: "hero-check", classes: "h-6 w-6 text-green-500") %>
          <h3 class="text-base font-semibold leading-7 text-gray-900">Migration Completed Successfully</h3>
        </div>
        <p class="mt-3 text-sm text-gray-600">
          Your databases have been successfully migrated to Ubicloud. You can now connect to your new
          PostgreSQL database using the connection details on the target database page.
        </p>

        <!-- Phase stepper (all done) -->
        <div class="mt-6">
          <% phase_progress.each do |phase_key, phase_label, status| %>
            <div class="flex items-center space-x-3 py-2">
              <%== part("components/icon", name: "hero-check", classes: "h-5 w-5 text-green-500") %>
              <span class="text-sm text-gray-500"><%= phase_label %></span>
            </div>
          <% end %>
        </div>

        <% if @migration.target_pg %>
          <div class="mt-6">
            <a href="<%= @project.path %><%= @migration.target_pg.path %>"
              class="inline-flex items-center justify-center rounded-md px-3 py-2 text-sm font-semibold text-white shadow-sm bg-orange-600 hover:bg-orange-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-600">
              Go to Target Database
            </a>
          </div>
        <% end %>
      </div>
    </div>

  <% elsif @migration.status == "failed" %>
    <!-- Failed -->
    <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
      <div class="px-4 py-5 sm:p-6">
        <div class="rounded-md bg-red-50 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <%== part("components/icon", name: "hero-x-mark", classes: "h-5 w-5 text-red-400") %>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">Migration Failed</h3>
              <p class="mt-2 text-sm text-red-700">
                <%= @migration.error_message || "An unexpected error occurred during migration. Please check the source database connectivity and try again." %>
              </p>
            </div>
          </div>
        </div>

        <div class="mt-6 flex items-center gap-x-6">
          <a href="<%= @project.path %><%= @pg.path %>/migration/create"
            class="inline-flex items-center justify-center rounded-md px-3 py-2 text-sm font-semibold text-white shadow-sm bg-orange-600 hover:bg-orange-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-600">
            Retry Migration
          </a>
          <a href="<%= @project.path %><%= @pg.path %>" class="text-sm font-semibold leading-6 text-gray-900">Back to Database</a>
        </div>
      </div>
    </div>

  <% elsif @migration.status == "cancelled" %>
    <!-- Cancelled -->
    <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white">
      <div class="px-4 py-5 sm:p-6">
        <div class="rounded-md bg-yellow-50 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-yellow-800">Migration Cancelled</h3>
              <p class="mt-2 text-sm text-yellow-700">
                This migration was cancelled. Any partially migrated data on the target may be incomplete.
                You can start a new migration if needed.
              </p>
            </div>
          </div>
        </div>

        <div class="mt-6 flex items-center gap-x-6">
          <a href="<%= @project.path %><%= @pg.path %>/migration/create"
            class="inline-flex items-center justify-center rounded-md px-3 py-2 text-sm font-semibold text-white shadow-sm bg-orange-600 hover:bg-orange-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-600">
            Start New Migration
          </a>
          <a href="<%= @project.path %><%= @pg.path %>" class="text-sm font-semibold leading-6 text-gray-900">Back to Database</a>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% nonce = SecureRandom.hex(32)
content_security_policy.add_script_src [:nonce, nonce] %>
<script nonce="<%= nonce %>">
  // Select-all checkbox for database selection
  const selectAll = document.getElementById('select-all-dbs');
  if (selectAll) {
    selectAll.addEventListener('change', function() {
      document.querySelectorAll('.db-checkbox').forEach(cb => {
        cb.checked = selectAll.checked;
      });
    });
  }
</script>
