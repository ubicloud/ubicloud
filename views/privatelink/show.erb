<div class="p-6">
  <%== part(
    "components/kv_data_card",
    data: [
      ["ID", @pl.ubid],
      ["State", @pl.display_state],
      ["Subnet", @pl.private_subnet.name],
      ["Service Name", @pl.service_name || "—"],
      ["Service ID", @pl.service_id || "—"],
      ["NLB ARN", @pl.nlb_arn || "—"]
    ]
  ) %>
</div>

<% if has_permission?("PrivateSubnet:edit", @pl.private_subnet) %>
  <div class="p-6">
    <div class="md:flex md:items-center md:justify-between pb-2 lg:pb-4">
      <div class="min-w-0 flex-1">
        <h3 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-2xl sm:tracking-tight">Danger Zone</h3>
      </div>
    </div>
    <div class="overflow-hidden rounded-lg shadow ring-1 ring-black ring-opacity-5 bg-white divide-y divide-gray-200">
      <div class="px-4 py-5 sm:p-6">
        <div class="sm:flex sm:items-center sm:justify-between">
          <div>
            <h3 class="text-base font-semibold leading-6 text-gray-900">Delete AWS PrivateLink endpoint</h3>
            <div class="mt-2 text-sm text-gray-500">
              <p>This action will permanently delete this PrivateLink endpoint and its associated NLB and VPC endpoint service in AWS.</p>
            </div>
          </div>
          <div class="mt-5 sm:ml-6 sm:mt-0 sm:flex sm:flex-shrink-0 sm:items-center">
            <%== part("components/delete_button", url: path(@pl), confirmation: @pl.ubid) %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
