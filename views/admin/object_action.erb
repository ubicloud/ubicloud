<% @page_title = "#{@klass.name} #{@obj.ubid}" %>

<% form(method: :post, id: "action-form", class: "form-vertical") do |f| %>
  <% @params.each do |name, value| %>
    <%== f.input(value.fetch(:type, "text"), key: name, label: name, required: true, **value) %>
  <% end %>
  <%== f.button(@label) %>
<% end %>
